{
  "compilerOptions": {
    "strict": true,
    "outDir": "bin",
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "bundler",
    "sourceMap": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "noFallthroughCasesInSwitch": true,
    "noImplicitReturns": true
  },
  "include": ["**/*.ts"],
  "exclude": ["node_modules", "bin"]
}
