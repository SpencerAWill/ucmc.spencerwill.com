# Copy to .env.local (gitignored) and fill in. Loaded automatically by
# `wrangler dev` / `@cloudflare/vite-plugin` during `pnpm dev`.
#
# Precedence (most → least specific, merged by wrangler v4+):
#   .env.<mode>.local  >  .env.local  >  .env.<mode>  >  .env
# Host process env also wins over any file because the devcontainer sets
# CLOUDFLARE_INCLUDE_PROCESS_ENV=true — export VAR in your shell to override.
#
# This file is LOCAL-DEV ONLY. Deployed dev/prod Workers get the same vars
# from Pulumi (`wrangler deploy --var`) and GitHub secrets (`wrangler secret
# put`) — see .github/workflows/web-deploy.yml. Missing any required var
# below will crash the server on the first request that reads it.

# ── Required for auth ────────────────────────────────────────────────────
APP_BASE_URL=http://localhost:3000
WEBAUTHN_RP_ID=localhost
WEBAUTHN_RP_NAME=UCMC (local)
RESEND_FROM=noreply@localhost
RESEND_FROM_NAME=UCMC (local)

# ── Secrets ──────────────────────────────────────────────────────────────
# Leave RESEND_API_KEY unset to use the console-log email adapter (magic
# links print to the dev-server terminal — NOT the browser console).
RESEND_API_KEY=

# HMAC signing key for the short-lived email-verification proof cookie.
# Must be >= 32 bytes of entropy. In deployed envs, set once per env via:
#   wrangler secret put SESSION_SECRET [--env production]
# Locally, any 32+ byte random string works. Rotating this value
# invalidates all outstanding proof cookies (desirable on compromise).
SESSION_SECRET=

# ── Seeding (db:seed:local only; not read at runtime) ────────────────────
# Email used as the seeded system_admin. This user is inserted with
# status='approved' so they can sign in on day one without the approval
# flow.
SEED_ADMIN_EMAIL=you@example.com
